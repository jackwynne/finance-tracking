{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    ".agents/skills/**",
    ".claude/skills/**",
    ".output/**",
    ".vite/**",
    "convex/_generated/**",
    "example/convex/_generated/**",
    "routeTree.gen.ts",
    "src/routeTree.gen.ts"
  ],
  "printWidth": 120,
  "quoteProps": "consistent",
  "semi": true,
  "singleQuote": true,
  "sortImports": true,
  "sortPackageJson": false,
  "trailingComma": "all"
}
